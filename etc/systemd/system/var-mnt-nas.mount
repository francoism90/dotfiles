[Unit]
Description=NFS NAS Mount
After=network-online.target nfs-client.target
Wants=network-online.target nfs-client.target

[Mount]
What=192.168.100.5:/
Where=/var/mnt/nas
Type=nfs
Options=rw,vers=4.2,nconnect=8,rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2,fsc,noatime,_netdev

[Install]
WantedBy=multi-user.target
