[Unit]
Description=Rclone network mount for %i
Documentation=man:rclone(1)
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
Environment="MOUNT_DIR=%h/mnt/%i"
Environment="REMOTE_PATH=/"
ExecStartPre=/usr/bin/mkdir -p ${MOUNT_DIR}
ExecStart=/home/linuxbrew/.linuxbrew/bin/rclone mount %i:${REMOTE_PATH} ${MOUNT_DIR} \
  --config=%h/.config/rclone/rclone.conf \
  --allow-other \
  --umask 0022 \
  --vfs-cache-mode full \
  --vfs-cache-max-size 50G \
  --vfs-cache-max-age 8h \
  --vfs-handle-caching 0s \
  --dir-cache-time 24h \
  --attr-timeout 24h \
  --buffer-size 64M \
  --vfs-read-chunk-size 32M \
  --vfs-read-chunk-size-limit 1G \
  --vfs-read-ahead 128M \
  --no-seek \
  --async-read=true
ExecStop=/usr/bin/fusermount3 -uz ${MOUNT_DIR}
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
